{
  "name": "tubenote",
  "version": "1.0.0",
  "main": "index.js",
  "license": "MIT",
  "private": true,
  "workspaces": [
    "packages/*"
  ],
  "scripts": {
    "lint": "eslint 'packages/**/*.{js,jsx,ts,tsx}'",
    "format": "prettier --write 'packages/**/*.{js,jsx,ts,tsx,json,css,md}'",
    "start:frontend": "yarn workspace frontend dev",
    "start:backend": "yarn workspace backend start",
    "start": "concurrently \"yarn start:frontend\" \"yarn start:backend\"",
    "prepare": "husky"
  },
  "devDependencies": {
    "@commitlint/cli": "^19.3.0",
    "@commitlint/config-conventional": "^19.2.2",
    "concurrently": "^8.2.2",
    "eslint": "^9.5.0",
    "husky": "^9.0.11",
    "prettier": "^3.3.2",
    "pretty-quick": "^4.0.0"
  }
}
